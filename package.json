{
  "name": "casefile",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "verify": "node scripts/verify.mjs && npm run typecheck && npm run lint && npm run build",
    "test:ai": "node --env-file=.env.local scripts/test-openai.mjs",
    "test:match": "node --experimental-strip-types scripts/test-match-engine.mjs",
    "test:truth-ledger": "node --experimental-strip-types scripts/test-truth-ledger.mjs",
    "test:ats": "node --experimental-strip-types scripts/test-ats-export.mjs",
    "test:taxonomy": "node --experimental-strip-types scripts/test-role-taxonomy.mjs",
    "test:rls": "node --env-file=.env.local scripts/test-rls.mjs",
    "test:uploads": "node scripts/test-uploads.mjs",
    "test:prompt-injection": "node scripts/test-prompt-injection.mjs",
    "test:xss": "node --env-file=.env.local scripts/test-xss.mjs",
    "release:gate": "node scripts/release-gate.mjs",
    "test:authorization": "node --env-file=.env.local scripts/test-api-authorization.mjs",
    "test:deletion": "node --env-file=.env.local scripts/test-account-deletion.mjs",
    "test:secrets": "gitleaks detect --source . --no-banner --config .gitleaks.toml"
