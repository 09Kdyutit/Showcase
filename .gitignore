# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# supabase CLI local cache (contains live DB connection strings)
supabase/.temp

# claude code local agent config (worktrees, locally installed skills)
.claude/

# typescript
*.tsbuildinfo
next-env.d.ts

# visual QA review artifacts — regenerate with npm run capture:screenshots
/screenshots

# prompt-eval run outputs — regenerate with npm run eval:prompts / test:multi-model
/evals/results

# locally installed agent skills (design tooling, not app code)
.github/skills/
